@startuml use-cases-sysadmin
title trawhile — System Administration (Epic 1)

left to right direction

actor "User" as User
actor "System Admin" as SysAdmin

User <|-- SysAdmin

rectangle "System Administration" {
    package "User Management" {
        usecase "View all users\n(UR-F004)" as UC_ViewUsers
        usecase "View pending invitations\n(UR-F005)" as UC_ViewPendingInvitations
        usecase "Invite user by email\n(UR-F006)" as UC_InviteUser
        usecase "Resend pending invitation\n(UR-F011)" as UC_ResendInvitation
        usecase "Withdraw pending invitation\n(UR-F007)" as UC_WithdrawPendingInvitation
        usecase "Remove user\n(UR-F008)" as UC_RemoveUser
        usecase "Manage user authorization\nassignments across tree\n(UR-F009)" as UC_ManageUserAuth
    }
    package "System Settings" {
        usecase "First-run member invite prompt\n(UR-F062)" as UC_FirstRunPrompt
        usecase "View system settings\n(read-only, all users)\n(UR-F010)" as UC_ViewSettings
    }
    package "Observability" {
        usecase "Monitor system health\nvia Prometheus endpoint\n(UR-F059)" as UC_Prometheus
    }
}

SysAdmin --> UC_ViewUsers
SysAdmin --> UC_ViewPendingInvitations
SysAdmin --> UC_InviteUser
SysAdmin --> UC_ResendInvitation
SysAdmin --> UC_WithdrawPendingInvitation
SysAdmin --> UC_RemoveUser
SysAdmin --> UC_ManageUserAuth
SysAdmin --> UC_FirstRunPrompt
SysAdmin --> UC_Prometheus
User --> UC_ViewSettings

note bottom of UC_ViewSettings
  Config values are set via application.yml
  at deployment; not editable via the UI.
end note

@enduml
