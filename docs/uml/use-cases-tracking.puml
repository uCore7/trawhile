@startuml use-cases-tracking
title trawhile — Time Tracking (Epic 3)

left to right direction

actor "User" as User

rectangle "Time Tracking" {
    package "Tracking Control" {
        usecase "View current tracking status\n(UR-F024)" as UC_TrackStatus
        usecase "Start tracking via node picker\n(UR-F026)" as UC_StartPicker
        usecase "Start tracking via quick-access\n(UR-F027)" as UC_StartQuick
        usecase "Switch node (atomic)\n(UR-F028)" as UC_Switch
        usecase "Stop tracking\n(UR-F029)" as UC_Stop
    }
    package "Time Record Management" {
        usecase "View record history\n(overlaps & gaps flagged)\n(UR-F025)" as UC_History
        usecase "Create retroactive record\n(UR-F031)" as UC_CreateEntry
        usecase "Edit time record\n(UR-F032)" as UC_EditEntry
        usecase "Delete time record\n(UR-F033)" as UC_DeleteEntry
        usecase "Duplicate time record\n(UR-F034)" as UC_DuplicateEntry
    }
    package "Quick-Access" {
        usecase "Add / remove / reorder\nnodes in quick-access\n(UR-F030)" as UC_QuickAccess
    }
}

User --> UC_TrackStatus
User --> UC_StartPicker
User --> UC_StartQuick
User --> UC_Switch
User --> UC_Stop
User --> UC_History
User --> UC_CreateEntry
User --> UC_EditEntry
User --> UC_DeleteEntry
User --> UC_DuplicateEntry
User --> UC_QuickAccess

@enduml
