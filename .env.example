# PostgreSQL
# Production: set a strong password
# Local dev (make development-db): defaults to "dev" if unset
DB_PASSWORD=changeme

# GitHub OAuth2 — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth2 — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In — https://developer.apple.com/account/resources/identifiers/list/serviceId
# CLIENT_ID = Services ID identifier; CLIENT_SECRET = signed JWT (regenerate annually)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Email address of the first admin user (must match the OAuth2 provider email)
BOOTSTRAP_ADMIN_EMAIL=

# Public domain name (used by Caddy for TLS)
DOMAIN=example.com
