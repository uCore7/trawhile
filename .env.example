# PostgreSQL password — used by the database container and the application container.
# Set a strong password in production.
DB_PASSWORD=changeme

# OAuth2 / OIDC providers
# At least one provider must have a non-empty client-id (SR-F065.F01).
# Only providers with a non-empty client-id are shown on the login page (SR-F067.F02).
# Leave client-id blank to disable a provider entirely.

# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In — https://developer.apple.com/account/resources/identifiers/list/serviceId
# CLIENT_ID: your Services ID identifier (e.g. com.example.trawhile)
# CLIENT_SECRET: a signed JWT — regenerate annually using Apple's private key tooling
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Microsoft Entra ID (Azure AD) — https://entra.microsoft.com/
# TENANT_ID: your directory tenant ID; use 'common' only for multi-tenant apps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Keycloak — https://www.keycloak.org/
# ISSUER_URI: your realm URL, e.g. https://keycloak.example.com/realms/company
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER_URI=

# Bootstrap admin — email address of the first System Admin.
# Must match the email returned by the OIDC provider on their first login.
# After the bootstrap login succeeds this variable has no further effect.
BOOTSTRAP_ADMIN_EMAIL=

# Public domain name used by Caddy for TLS certificate provisioning.
DOMAIN=example.com

# Management port for the Prometheus metrics scrape endpoint (SR-F059.F01).
# Not routed through Caddy — access is restricted by Docker network topology.
MANAGEMENT_PORT=9090
